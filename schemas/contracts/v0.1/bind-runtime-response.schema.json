{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BindRuntimeResponse",
  "description": "Acknowledgement of a runtime binding operation.",
  "type": "object",
  "properties": {
    "accepted": {
      "type": "boolean"
    },
    "binding_id": {
      "type": "string"
    },
    "idempotent_replay": {
      "type": "boolean"
    },
    "run_id": {
      "$ref": "#/$defs/RunId"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "binding_id",
    "accepted",
    "idempotent_replay"
  ],
  "$defs": {
    "RunId": {
      "description": "An organization-scoped Agent Run identifier.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "SchemaVersion": {
      "description": "Wire schema versions understood by this crate.",
      "oneOf": [
        {
          "description": "Agent Execution Record schema v0.1.",
          "type": "string",
          "const": "0.1"
        }
      ]
    }
  }
}
