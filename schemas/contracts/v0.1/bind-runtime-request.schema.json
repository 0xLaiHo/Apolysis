{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BindRuntimeRequest",
  "description": "Idempotent request to bind a runtime identity under a run lease.",
  "type": "object",
  "properties": {
    "binding": {
      "$ref": "#/$defs/RuntimeBinding"
    },
    "client_operation_id": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "lease_id": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "request_digest": {
      "type": "string",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[0-9a-f]{64}$"
    },
    "run_id": {
      "$ref": "#/$defs/RunId"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "client_operation_id",
    "request_digest",
    "run_id",
    "lease_id",
    "binding"
  ],
  "$defs": {
    "RunId": {
      "description": "An organization-scoped Agent Run identifier.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "RuntimeAttribution": {
      "description": "Explicit quality of a run-to-runtime correlation.",
      "oneOf": [
        {
          "description": "An explicitly propagated identity was independently validated.",
          "type": "string",
          "const": "exact"
        },
        {
          "description": "A non-unique heuristic selected one most likely runtime.",
          "type": "string",
          "const": "inferred"
        },
        {
          "description": "Multiple plausible runtime identities remain.",
          "type": "string",
          "const": "ambiguous"
        },
        {
          "description": "No qualifying runtime identity could be assigned.",
          "type": "string",
          "const": "unattributed"
        }
      ]
    },
    "RuntimeBinding": {
      "description": "A versioned, evidence-backed relation between a run and runtime identity.",
      "type": "object",
      "properties": {
        "alternative_runtime_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RuntimeBindingCandidate"
          }
        },
        "asserting_source_id": {
          "$ref": "#/$defs/SourceId"
        },
        "attribution": {
          "$ref": "#/$defs/RuntimeAttribution"
        },
        "binding_id": {
          "type": "string",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
        },
        "confidence_bps": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 10000,
          "minimum": 0
        },
        "evidence_basis": {
          "$ref": "#/$defs/RuntimeBindingBasis"
        },
        "evidence_basis_ref": {
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        },
        "identity_kind": {
          "$ref": "#/$defs/RuntimeIdentityKind"
        },
        "identity_ref": {
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "valid_from_unix_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 1
        },
        "valid_until_unix_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "binding_id",
        "asserting_source_id",
        "identity_kind",
        "identity_ref",
        "valid_from_unix_ms",
        "evidence_basis",
        "evidence_basis_ref",
        "attribution",
        "reason_codes",
        "alternative_runtime_candidates"
      ]
    },
    "RuntimeBindingBasis": {
      "description": "Evidence method used to establish a runtime correlation.",
      "oneOf": [
        {
          "description": "A propagated runtime identifier was checked at an independent boundary.",
          "type": "string",
          "const": "propagated_and_validated"
        },
        {
          "description": "A provider asserted the runtime relation inside its own boundary.",
          "type": "string",
          "const": "provider_attestation"
        },
        {
          "description": "PID, time, path, argument, name, or comparable heuristic matching.",
          "type": "string",
          "const": "heuristic_match"
        },
        {
          "description": "No qualifying basis was available.",
          "type": "string",
          "const": "unavailable"
        }
      ]
    },
    "RuntimeBindingCandidate": {
      "description": "One scored alternative retained for an ambiguous runtime relation.",
      "type": "object",
      "properties": {
        "confidence_bps": {
          "type": "integer",
          "format": "uint16",
          "maximum": 10000,
          "minimum": 0
        },
        "evidence_basis_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "identity_ref": {
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "identity_ref",
        "reason_codes",
        "confidence_bps",
        "evidence_basis_refs"
      ]
    },
    "RuntimeIdentityKind": {
      "description": "Runtime identity categories supported by the v0.1 binding contract.",
      "oneOf": [
        {
          "description": "Operating-system process identity.",
          "type": "string",
          "const": "process"
        },
        {
          "description": "Linux cgroup identity.",
          "type": "string",
          "const": "cgroup"
        },
        {
          "description": "Container-runtime identity.",
          "type": "string",
          "const": "container"
        },
        {
          "description": "Kubernetes Pod identity.",
          "type": "string",
          "const": "pod"
        },
        {
          "description": "Virtual-machine identity.",
          "type": "string",
          "const": "vm"
        },
        {
          "description": "CI or development runner identity.",
          "type": "string",
          "const": "runner"
        },
        {
          "description": "Provider-managed workload identity.",
          "type": "string",
          "const": "provider_workload"
        }
      ]
    },
    "SchemaVersion": {
      "description": "Wire schema versions understood by this crate.",
      "oneOf": [
        {
          "description": "Agent Execution Record schema v0.1.",
          "type": "string",
          "const": "0.1"
        }
      ]
    },
    "SourceId": {
      "description": "A registered Evidence Source identifier.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    }
  }
}
