{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TypedEvidencePayload",
  "description": "Every structure-only v0.1 payload body accepted by the typed evidence seam.",
  "oneOf": [
    {
      "description": "Agent lifecycle evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/AgentLifecycleBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "agent_lifecycle"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Delegation lifecycle evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/DelegationLifecycleBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "delegation_lifecycle"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Tool interaction evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/ToolInteractionBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "tool_interaction"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "MCP or A2A protocol interaction evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/ProtocolInteractionBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "protocol_interaction"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Policy decision evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/PolicyDecisionBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "policy_decision"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Policy actuation evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/ActuationReportBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "actuation_report"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Runtime effect evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/RuntimeEffectBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "runtime_effect"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Claimed outcome evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/OutcomeClaimBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "outcome_claim"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Independently verified outcome evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/OutcomeVerificationBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "outcome_verification"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    },
    {
      "description": "Source health and loss evidence.",
      "type": "object",
      "properties": {
        "body": {
          "$ref": "#/$defs/SourceDiagnosticBody"
        },
        "evidence_type": {
          "type": "string",
          "const": "source_diagnostic"
        }
      },
      "required": [
        "evidence_type",
        "body"
      ]
    }
  ],
  "$defs": {
    "ActuationAction": {
      "description": "Allowlisted actions an enforcement point can report.",
      "oneOf": [
        {
          "description": "Permit the subject operation to continue.",
          "type": "string",
          "const": "allow"
        },
        {
          "description": "Prevent the subject operation.",
          "type": "string",
          "const": "block"
        },
        {
          "description": "Terminate an already-running subject.",
          "type": "string",
          "const": "terminate"
        },
        {
          "description": "Isolate the subject from a boundary.",
          "type": "string",
          "const": "isolate"
        },
        {
          "description": "Apply a narrower capability or resource limit.",
          "type": "string",
          "const": "restrict"
        },
        {
          "description": "Emit a notification without changing execution.",
          "type": "string",
          "const": "notify"
        }
      ]
    },
    "ActuationReportBody": {
      "description": "A report of actuation tied to the policy decision that requested it.",
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/ActuationAction"
        },
        "actuation_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "actuator_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "decision_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "subject_ref": {
          "$ref": "#/$defs/EvidenceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "actuation_ref",
        "decision_ref",
        "actuator_ref",
        "subject_ref",
        "action",
        "outcome"
      ]
    },
    "AgentLifecycleBody": {
      "description": "A content-off agent lifecycle observation.",
      "type": "object",
      "properties": {
        "agent_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "event": {
          "$ref": "#/$defs/AgentLifecycleEvent"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "supervisor_agent_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "agent_ref",
        "event",
        "outcome"
      ]
    },
    "AgentLifecycleEvent": {
      "description": "Agent lifecycle event names exposed by the structure-only contract.",
      "oneOf": [
        {
          "description": "An agent identity was allocated.",
          "type": "string",
          "const": "spawned"
        },
        {
          "description": "The agent began work.",
          "type": "string",
          "const": "started"
        },
        {
          "description": "The agent was suspended.",
          "type": "string",
          "const": "suspended"
        },
        {
          "description": "A suspended agent resumed.",
          "type": "string",
          "const": "resumed"
        },
        {
          "description": "The agent reported completion.",
          "type": "string",
          "const": "completed"
        },
        {
          "description": "The agent reported a failure.",
          "type": "string",
          "const": "failed"
        },
        {
          "description": "The agent was cancelled.",
          "type": "string",
          "const": "cancelled"
        }
      ]
    },
    "AgentProtocol": {
      "description": "Agent protocol families supported in v0.1.",
      "oneOf": [
        {
          "description": "Model Context Protocol.",
          "type": "string",
          "const": "mcp"
        },
        {
          "description": "Agent-to-Agent protocol.",
          "type": "string",
          "const": "a2a"
        }
      ]
    },
    "DelegationLifecycleBody": {
      "description": "A content-off delegation relationship and lifecycle observation.",
      "type": "object",
      "properties": {
        "delegate_agent_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "delegation_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "delegator_agent_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "event": {
          "$ref": "#/$defs/DelegationLifecycleEvent"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "task_ref": {
          "$ref": "#/$defs/EvidenceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "delegation_ref",
        "delegator_agent_ref",
        "delegate_agent_ref",
        "task_ref",
        "event",
        "outcome"
      ]
    },
    "DelegationLifecycleEvent": {
      "description": "Delegation lifecycle event names.",
      "oneOf": [
        {
          "description": "Delegation was requested.",
          "type": "string",
          "const": "requested"
        },
        {
          "description": "The delegate accepted the work.",
          "type": "string",
          "const": "accepted"
        },
        {
          "description": "The delegate reported completion.",
          "type": "string",
          "const": "completed"
        },
        {
          "description": "The delegate reported failure.",
          "type": "string",
          "const": "failed"
        },
        {
          "description": "Delegated work was cancelled.",
          "type": "string",
          "const": "cancelled"
        }
      ]
    },
    "DiagnosticSeverity": {
      "description": "Source diagnostic severity.",
      "oneOf": [
        {
          "description": "Informational source state.",
          "type": "string",
          "const": "info"
        },
        {
          "description": "A gap or degraded source state.",
          "type": "string",
          "const": "warning"
        },
        {
          "description": "A source failure that prevents expected evidence.",
          "type": "string",
          "const": "error"
        }
      ]
    },
    "EvidenceRef": {
      "description": "An opaque reference carried instead of prompts, responses, arguments, or bodies.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "InteractionEvent": {
      "description": "Tool interaction lifecycle events.",
      "oneOf": [
        {
          "description": "The interaction was requested but not observed running.",
          "type": "string",
          "const": "requested"
        },
        {
          "description": "The interaction began.",
          "type": "string",
          "const": "started"
        },
        {
          "description": "The interaction reached a terminal observation.",
          "type": "string",
          "const": "completed"
        }
      ]
    },
    "OperationOutcome": {
      "description": "Bounded outcome vocabulary shared by attempted operations.",
      "oneOf": [
        {
          "description": "The operation reached its requested terminal state.",
          "type": "string",
          "const": "succeeded"
        },
        {
          "description": "The operation ran but did not reach its requested terminal state.",
          "type": "string",
          "const": "failed"
        },
        {
          "description": "Policy or an enforcement point prevented the operation.",
          "type": "string",
          "const": "denied"
        },
        {
          "description": "The operation has not reached a terminal state.",
          "type": "string",
          "const": "pending"
        },
        {
          "description": "Available evidence does not establish the operation result.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "OutcomeClaimBody": {
      "description": "An agent or provider outcome claim without prose or result content.",
      "type": "object",
      "properties": {
        "basis_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "claim_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "claim_type": {
          "$ref": "#/$defs/OutcomeClaimKind"
        },
        "claimant_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "subject_ref": {
          "$ref": "#/$defs/EvidenceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "claim_ref",
        "claimant_ref",
        "subject_ref",
        "claim_type",
        "outcome"
      ]
    },
    "OutcomeClaimKind": {
      "description": "Allowlisted claim classes.",
      "oneOf": [
        {
          "description": "The assigned task completed.",
          "type": "string",
          "const": "task_completed"
        },
        {
          "description": "A referenced test run passed.",
          "type": "string",
          "const": "tests_passed"
        },
        {
          "description": "A referenced artifact was created.",
          "type": "string",
          "const": "artifact_created"
        },
        {
          "description": "A referenced external state changed.",
          "type": "string",
          "const": "state_changed"
        },
        {
          "description": "A referenced deployment completed.",
          "type": "string",
          "const": "deployment_completed"
        }
      ]
    },
    "OutcomeComparisonState": {
      "description": "Comparison between a claim and an independent outcome check.",
      "oneOf": [
        {
          "description": "The independent check matches the claimed outcome.",
          "type": "string",
          "const": "match"
        },
        {
          "description": "The independent check disagrees with the claimed outcome.",
          "type": "string",
          "const": "mismatch"
        },
        {
          "description": "A definitive comparison is not currently available.",
          "type": "string",
          "const": "unresolved"
        }
      ]
    },
    "OutcomeVerificationBody": {
      "description": "An independent comparison of an outcome claim with an opaque observation.",
      "type": "object",
      "properties": {
        "claim_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "comparison": {
          "$ref": "#/$defs/OutcomeComparisonState"
        },
        "observation_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "verification_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "verifier_ref": {
          "$ref": "#/$defs/EvidenceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "verification_ref",
        "claim_ref",
        "verifier_ref",
        "observation_ref",
        "comparison",
        "outcome"
      ]
    },
    "PolicyDecisionBody": {
      "description": "A policy decision kept separate from any enforcement report.",
      "type": "object",
      "properties": {
        "basis_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "decision": {
          "$ref": "#/$defs/PolicyDecisionKind"
        },
        "decision_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "policy_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "reason_code": {
          "$ref": "#/$defs/PolicyReasonCode"
        },
        "subject_ref": {
          "$ref": "#/$defs/EvidenceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "decision_ref",
        "policy_ref",
        "subject_ref",
        "decision",
        "reason_code"
      ]
    },
    "PolicyDecisionKind": {
      "description": "Policy evaluation decisions.",
      "oneOf": [
        {
          "description": "Policy permits the subject operation.",
          "type": "string",
          "const": "allow"
        },
        {
          "description": "Policy denies the subject operation.",
          "type": "string",
          "const": "deny"
        },
        {
          "description": "A separate approval is required before actuation.",
          "type": "string",
          "const": "require_approval"
        },
        {
          "description": "The policy does not apply to the subject.",
          "type": "string",
          "const": "not_applicable"
        },
        {
          "description": "The source cannot establish a decision.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "PolicyReasonCode": {
      "description": "Stable, content-free policy reason classes.",
      "oneOf": [
        {
          "description": "An explicit rule matched.",
          "type": "string",
          "const": "matched_rule"
        },
        {
          "description": "The policy default determined the decision.",
          "type": "string",
          "const": "default_rule"
        },
        {
          "description": "A human approval determined the decision.",
          "type": "string",
          "const": "human_approval"
        },
        {
          "description": "The subject request was structurally invalid.",
          "type": "string",
          "const": "invalid_request"
        },
        {
          "description": "Evidence was insufficient to decide.",
          "type": "string",
          "const": "insufficient_context"
        },
        {
          "description": "The policy service was unavailable.",
          "type": "string",
          "const": "policy_unavailable"
        }
      ]
    },
    "ProtocolInteractionBody": {
      "description": "An MCP or A2A interaction represented only by identities and metadata.",
      "type": "object",
      "properties": {
        "agent_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "interaction_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "operation": {
          "$ref": "#/$defs/ProtocolOperation"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "peer_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "protocol": {
          "$ref": "#/$defs/AgentProtocol"
        },
        "request_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "response_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "interaction_ref",
        "agent_ref",
        "protocol",
        "peer_ref",
        "operation",
        "outcome"
      ]
    },
    "ProtocolOperation": {
      "description": "Allowlisted protocol operations; they carry no request or response body.",
      "oneOf": [
        {
          "description": "Invoke an MCP tool.",
          "type": "string",
          "const": "tool_call"
        },
        {
          "description": "Read an MCP resource.",
          "type": "string",
          "const": "resource_read"
        },
        {
          "description": "Resolve an MCP prompt template by reference.",
          "type": "string",
          "const": "prompt_template"
        },
        {
          "description": "Submit an A2A task.",
          "type": "string",
          "const": "task_submit"
        },
        {
          "description": "Observe or publish an A2A task update.",
          "type": "string",
          "const": "task_update"
        },
        {
          "description": "Exchange an artifact reference without artifact content.",
          "type": "string",
          "const": "artifact_reference"
        },
        {
          "description": "Exchange a message reference without message content.",
          "type": "string",
          "const": "message_reference"
        }
      ]
    },
    "RuntimeEffectBody": {
      "description": "A host or managed-runtime effect represented by opaque identities.",
      "type": "object",
      "properties": {
        "effect_kind": {
          "$ref": "#/$defs/RuntimeEffectKind"
        },
        "effect_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "outcome": {
          "$ref": "#/$defs/OperationOutcome"
        },
        "runtime_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "target_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "effect_ref",
        "runtime_ref",
        "effect_kind",
        "outcome"
      ]
    },
    "RuntimeEffectKind": {
      "description": "Runtime effect classes visible without retaining raw values.",
      "oneOf": [
        {
          "description": "Process lifecycle or control effect.",
          "type": "string",
          "const": "process"
        },
        {
          "description": "File or filesystem effect.",
          "type": "string",
          "const": "file"
        },
        {
          "description": "Network effect.",
          "type": "string",
          "const": "network"
        },
        {
          "description": "Identity or credential boundary effect.",
          "type": "string",
          "const": "identity"
        },
        {
          "description": "Container, Pod, VM, or infrastructure effect.",
          "type": "string",
          "const": "workload"
        }
      ]
    },
    "SourceDiagnosticBody": {
      "description": "A source-health observation without logs or captured content.",
      "type": "object",
      "properties": {
        "affected_count": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 1
        },
        "diagnostic_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "kind": {
          "$ref": "#/$defs/SourceDiagnosticKind"
        },
        "related_event_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "severity": {
          "$ref": "#/$defs/DiagnosticSeverity"
        },
        "source_ref": {
          "$ref": "#/$defs/EvidenceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "diagnostic_ref",
        "source_ref",
        "kind",
        "severity"
      ]
    },
    "SourceDiagnosticKind": {
      "description": "Stable source diagnostic classes.",
      "oneOf": [
        {
          "description": "The source started a stream.",
          "type": "string",
          "const": "started"
        },
        {
          "description": "The source reported liveness.",
          "type": "string",
          "const": "heartbeat"
        },
        {
          "description": "The source detected missing evidence.",
          "type": "string",
          "const": "loss_detected"
        },
        {
          "description": "The source enabled sampling.",
          "type": "string",
          "const": "sampling_enabled"
        },
        {
          "description": "The source truncated evidence.",
          "type": "string",
          "const": "evidence_truncated"
        },
        {
          "description": "The source failed.",
          "type": "string",
          "const": "failed"
        },
        {
          "description": "The source recovered after a failure.",
          "type": "string",
          "const": "recovered"
        },
        {
          "description": "The source ended a stream.",
          "type": "string",
          "const": "finished"
        }
      ]
    },
    "ToolCapability": {
      "description": "Allowlisted tool capability classes.",
      "oneOf": [
        {
          "description": "Process creation or control.",
          "type": "string",
          "const": "process"
        },
        {
          "description": "File or filesystem access.",
          "type": "string",
          "const": "file"
        },
        {
          "description": "Network access.",
          "type": "string",
          "const": "network"
        },
        {
          "description": "Browser or UI automation.",
          "type": "string",
          "const": "browser"
        },
        {
          "description": "Database access.",
          "type": "string",
          "const": "database"
        },
        {
          "description": "Messaging or collaboration system access.",
          "type": "string",
          "const": "messaging"
        },
        {
          "description": "Identity or credential boundary access.",
          "type": "string",
          "const": "identity"
        },
        {
          "description": "Workload or infrastructure control.",
          "type": "string",
          "const": "workload"
        }
      ]
    },
    "ToolInteractionBody": {
      "description": "A tool interaction without raw arguments or results.",
      "type": "object",
      "properties": {
        "agent_ref": {
          "$ref": "#/$defs/EvidenceRef"
        },
        "capability": {
          "$ref": "#/$defs/ToolCapability"
        },
        "event": {
          "$ref": "#/$defs/InteractionEvent"
        },
        "interaction_ref": {
