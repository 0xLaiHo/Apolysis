{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinishRunResponse",
  "description": "Gateway-assigned finalization state and deadline.",
  "type": "object",
  "properties": {
    "finalization_deadline_unix_ms": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "idempotent_replay": {
      "type": "boolean"
    },
    "run_id": {
      "$ref": "#/$defs/RunId"
    },
    "schema_version": {
      "$ref": "#/$defs/SchemaVersion"
    },
    "state": {
      "$ref": "#/$defs/RunState"
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "state",
    "idempotent_replay"
  ],
  "$defs": {
    "RunId": {
      "description": "An organization-scoped Agent Run identifier.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "RunState": {
      "description": "Lifecycle states for an Agent Run.",
      "oneOf": [
        {
          "description": "Identity and source policy are being validated.",
          "type": "string",
          "const": "opening"
        },
        {
          "description": "Registered sources may contribute evidence.",
          "type": "string",
          "const": "active"
        },
        {
          "description": "Terminal declarations and gaps are being reconciled.",
          "type": "string",
          "const": "finishing"
        },
        {
          "description": "The run is sealed without an unresolved required-source gap.",
          "type": "string",
          "const": "finished"
        },
        {
          "description": "The run is sealed with at least one terminal or evidence gap.",
          "type": "string",
          "const": "incomplete"
        }
      ]
    },
    "SchemaVersion": {
      "description": "Wire schema versions understood by this crate.",
      "oneOf": [
        {
          "description": "Agent Execution Record schema v0.1.",
          "type": "string",
          "const": "0.1"
        }
      ]
    }
  }
}
